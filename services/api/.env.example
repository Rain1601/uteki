# Web 前端允许跨域的来源（逗号分隔）
UTEKI_CORS_ORIGINS=http://localhost:3000

# ──────────────────────────────────────────────────────────────────────
# LLM providers
#
# Routing：skill / 调用方传入 model id 形如 "<provider>/<upstream_model>"
#   anthropic/claude-sonnet-4-6        → 直连 Anthropic（享 prompt caching）
#   deepseek/deepseek-chat             → 直连 DeepSeek（单价低 10x，调度首选）
#   deepseek/deepseek-reasoner         → 带 CoT 的 R1
#   openrouter/anthropic/claude-...    → 走 OpenRouter
#   aihubmix/gpt-4o-mini               → 走 AiHubMix
# 未带前缀的 model id 走下方 legacy UTEKI_LLM_* 配置。
# ──────────────────────────────────────────────────────────────────────

# Anthropic 原生（推荐用于研报合成 — 长 SKILL.md 跟随度最佳 + 90% 缓存折扣）
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# DeepSeek（推荐用于调度任务 — Sonnet 1/10 单价，OpenAI 兼容协议）
DEEPSEEK_API_KEY=

# 中转 / 聚合
OPENROUTER_API_KEY=
AIHUBMIX_API_KEY=

# Legacy OpenAI-compat fallback（model id 不带前缀时走这里）
UTEKI_LLM_BASE_URL=
UTEKI_LLM_API_KEY=
UTEKI_LLM_MODEL=gpt-4o-mini

# 是否启用模拟流式响应（无需 API key 即可端到端跑通骨架）
UTEKI_USE_MOCK_LLM=true

# 默认 skill 用什么模型（被前端 / 调用方覆盖）
#   - 想跑真 Claude   → anthropic/claude-sonnet-4-6
#   - 想跑 DeepSeek   → deepseek/deepseek-chat
UTEKI_DEFAULT_MODEL=deepseek/deepseek-chat

# ── M4 multi-tenant / auth ───────────────────────────────────────────
UTEKI_DB_URL=sqlite:///data/uteki.db
# 32+ char random; prod must override
UTEKI_JWT_SECRET=change-me-to-a-random-32-char-string
# false = anonymous requests fall back to demo@local; true = strict 401
UTEKI_AUTH_REQUIRED=true
UTEKI_OAUTH_REDIRECT_BASE=http://localhost:8000
UTEKI_FRONTEND_BASE=http://localhost:3000

# OAuth — empty in dev disables the buttons in the UI
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
