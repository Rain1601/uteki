# Web 前端允许跨域的来源（逗号分隔）
UTEKI_CORS_ORIGINS=http://localhost:3000

# ──────────────────────────────────────────────────────────────────────
# LLM providers
#
# Routing：skill / 调用方传入 model id 形如 "<provider>/<upstream_model>"
#   anthropic/claude-sonnet-4-6        → 直连 Anthropic（享 prompt caching）
#   deepseek/deepseek-chat             → 直连 DeepSeek（单价低 10x，调度首选）
#   deepseek/deepseek-reasoner         → 带 CoT 的 R1
#   openrouter/anthropic/claude-...    → 走 OpenRouter
#   aihubmix/gpt-4o-mini               → 走 AiHubMix
# 未带前缀的 model id 走下方 legacy UTEKI_LLM_* 配置。
# ──────────────────────────────────────────────────────────────────────

# Anthropic 原生（推荐用于研报合成 — 长 SKILL.md 跟随度最佳 + 90% 缓存折扣）
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# DeepSeek（推荐用于调度任务 — Sonnet 1/10 单价，OpenAI 兼容协议）
DEEPSEEK_API_KEY=

# 中转 / 聚合
OPENROUTER_API_KEY=
AIHUBMIX_API_KEY=

# Legacy OpenAI-compat fallback（model id 不带前缀时走这里）
UTEKI_LLM_BASE_URL=
UTEKI_LLM_API_KEY=
UTEKI_LLM_MODEL=gpt-4o-mini

# 是否启用模拟流式响应（无需 API key 即可端到端跑通骨架）
UTEKI_USE_MOCK_LLM=true
# 是否启用模拟市场/财务/新闻数据。默认跟随 UTEKI_USE_MOCK_LLM；
# 真投研本地运行建议设为 false，测试保持 true。
UTEKI_USE_MOCK_DATA=true

# ──────────────────────────────────────────────────────────────────────
# Market / financial / news data providers
# ──────────────────────────────────────────────────────────────────────

# Financial Modeling Prep：uteki.open 用于 point-in-time 财报；当前作为可选增强。
FMP_API_KEY=

# Google Custom Search：uteki.open 的新闻/网页检索入口；未配置时回退到 DDGS。
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# 默认 skill 用什么模型（被前端 / 调用方覆盖）
#   - 想跑真 Claude   → anthropic/claude-sonnet-4-6
#   - 想跑 DeepSeek   → deepseek/deepseek-chat
UTEKI_DEFAULT_MODEL=deepseek/deepseek-chat

# ── M4 multi-tenant / auth + storage ─────────────────────────────────
UTEKI_DB_URL=sqlite:///data/uteki.db
# RunStore backend: "sqlite" (durable, cross-process visible — needed
# so the MCP server can read runs the HTTP server created) or "memory"
# (process-local, faster, dies on restart). Default sqlite.
UTEKI_RUN_STORE=sqlite
# 32+ char random; prod must override
UTEKI_JWT_SECRET=change-me-to-a-random-32-char-string
# false = anonymous requests fall back to demo@local; true = strict 401
UTEKI_AUTH_REQUIRED=true
# Local-only full access override. Keep false outside local development.
# When UTEKI_AUTH_REQUIRED=false this defaults to true if unset.
UTEKI_LOCAL_ALL_PERMISSIONS=false
# Reader can view runs/artifacts/trace; admin can operate agents/evals/admin tools.
# Comma-separated. GitHub login/id allowlists apply to GitHub OAuth identities.
UTEKI_ADMIN_EMAILS=
UTEKI_ADMIN_GITHUB_LOGINS=
UTEKI_ADMIN_GITHUB_IDS=

# ── 010 · single-owner deployment ────────────────────────────────────
# Set the owner's email + GitHub login for the public-readonly product
# model. Anyone in this allowlist gets admin role on OAuth callback;
# nobody else gets a token issued. The first email in OWNER_EMAILS
# becomes the canonical "owner" user record at startup, so data
# partitioning under owner.id works before they ever sign in.
#
# These are unioned with UTEKI_ADMIN_* above — owner is the preferred
# vocabulary going forward; admin_* remain functional for back-compat.
# Comma-separated.
UTEKI_OWNER_EMAILS=
UTEKI_OWNER_GITHUB_LOGINS=
UTEKI_OAUTH_REDIRECT_BASE=http://localhost:8000
UTEKI_FRONTEND_BASE=http://localhost:3000

# OAuth — empty in dev disables the buttons in the UI
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Artifact storage backend ──────────────────────────────────────────
# "fs" (default) → LocalFileArtifactStore under data/runs/. Used for
#                  dev, tests, and any deployment not on GCS.
# "gcs"          → GCSArtifactStore writing to gs://$UTEKI_GCS_BUCKET/.
#                  Requires the [gcs] extra: `uv sync --extra gcs`.
UTEKI_STORAGE_BACKEND=fs
# GCS bucket name (without gs:// prefix). Required when storage_backend=gcs.
UTEKI_GCS_BUCKET=uteki-artifacts
# Optional service-account JSON path for local dev against a real GCS bucket.
# Leave empty in Cloud Run — Application Default Credentials (ADC) take over
# via the attached service account.
UTEKI_GCS_CREDENTIALS_PATH=
